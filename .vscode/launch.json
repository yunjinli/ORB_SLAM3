{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(gdb) Launch Monocular Euroc",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/Examples/Monocular/mono_euroc",
            "args": [
                "${workspaceFolder}/Vocabulary/ORBvoc.txt",
                "${workspaceFolder}/Examples/Monocular/EuRoC.yaml",
                "${workspaceFolder}/MH01",
                "${workspaceFolder}/Examples/Monocular/EuRoC_TimeStamps/MH01.txt"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build ORB_SLAM3 (Debug)"
        }
    ]
}
